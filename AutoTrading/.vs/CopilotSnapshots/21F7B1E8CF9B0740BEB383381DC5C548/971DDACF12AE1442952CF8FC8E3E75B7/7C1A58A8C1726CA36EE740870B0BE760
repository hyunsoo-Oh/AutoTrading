using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Data;
using System.Drawing;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows.Forms;

namespace AutoTrading.Controls
{
    public partial class StatusLabel : UserControl
    {
        public enum StatusEnum
        {
            Red, Green, Gray, Blue
        }
        private ToolTip _toolTip = new ToolTip();
        private string _tipText = string.Empty;

        private StatusEnum _status = StatusEnum.Gray;
        private string _statusText = string.Empty;

        public StatusLabel()
        {
            InitializeComponent();
            this.Height = 24;
            this.DoubleBuffered = true;
        }

        [Category("Custom")]
        [Description("마우스 커서를 올릴 때 나오는 설명")]
        public string Tip
        {
            get { return _tipText; }
            set
            {
                _tipText = value;
                _toolTip.SetToolTip(this, _tipText);

                Invalidate();
            }
        }

        [Category("Custom")]
        [Description("상태 표시용 원형 인디케이터 색상 (Red, Green, Gray, Blue)")]
        public StatusEnum Status
        {
            get => _status;
            set
            {
                _status = value;
                Invalidate(); // 다시 그리기
            }
        }

        [Category("Custom")]
        [Description("인디케이터 옆에 표시되는 상태 텍스트")]
        public string StatusText
        {
            get => _statusText;
            set
            {
                _statusText = value;
                Invalidate();
            }
        }

        private Color GetStatusColor()
        {
            return _status switch
            {
                StatusEnum.Red => Color.Red,
                StatusEnum.Green => Color.LimeGreen,
                StatusEnum.Blue => Color.DodgerBlue,
                StatusEnum.Gray => Color.Gray,
                _ => Color.Gray
            };
        }

        protected override void OnPaint(PaintEventArgs e)
        {
            base.OnPaint(e);

            Graphics g = e.Graphics;

            // 원 그리기
            int leftMargin = 8;       // 왼쪽 여백
            int circleSize = 21;
            int circleTextGap = 6;    // 원과 텍스트 간격

            int circleY = (Height - circleSize) / 2;    // 세로 중앙에 배치

            using (Brush brush = new SolidBrush(GetStatusColor()))
            {
                g.FillEllipse(brush, leftMargin, circleY, circleSize, circleSize);
            }

            // 텍스트
            // 텍스트 위치
            float textX = leftMargin + circleSize + circleTextGap;
            float textY = (Height - Font.Height) / 2;


            using (Brush brush = new SolidBrush(ForeColor))
            {
                g.DrawString(_statusText, Font, brush, textX, textY);
            }
        }
    }
}
