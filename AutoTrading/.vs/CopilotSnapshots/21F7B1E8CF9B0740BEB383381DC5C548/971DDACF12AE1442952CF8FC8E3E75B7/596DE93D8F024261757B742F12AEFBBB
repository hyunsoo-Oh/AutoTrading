using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Data;
using System.Drawing;
using System.Drawing.Drawing2D;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows.Forms;
using System.Xml;

namespace AutoTrading.Controls.Common
{
    public enum BadgeStatus
    {
        Neutral,
        Success,
        Warning,
        Danger,
        Info
    }

    public partial class StatusBadgeControl : UserControl
    {
        private BadgeStatus _status = BadgeStatus.Neutral;
        private string _textValue = "Status";

        public StatusBadgeControl()
        {
            InitializeComponent();
            InitializeStyle();
            ApplyStyle();
        }

        [Category("Custom")]
        [Description("뱃지에 표시되는 텍스트")]
        public string TextValue
        {
            get => _textValue;
            set
            {
                _textValue = value;
                label1.Text = value;
                Invalidate();
            }
        }

        [Category("Custom")]
        [Description("뱃지 상태 (Neutral, Success, Warning, Danger, Info)에 따라 색상 변경")]
        public BadgeStatus Status
        {
            get => _status;
            set
            {
                _status = value;
                ApplyStyle();
                Invalidate();
            }
        }

        private void InitializeStyle()
        {
            SetStyle(ControlStyles.AllPaintingInWmPaint |
                     ControlStyles.UserPaint |
                     ControlStyles.OptimizedDoubleBuffer |
                     ControlStyles.ResizeRedraw, true);

            label1.Text = _textValue;
        }

        private void ApplyStyle()
        {
            Color backColor;
            Color foreColor;
            Color borderColor;

            switch (_status)
            {
                case BadgeStatus.Success:
                    backColor = Color.FromArgb(230, 244, 234);
                    foreColor = Color.FromArgb(46, 125, 50);
                    borderColor = Color.FromArgb(165, 214, 167);
                    break;

                case BadgeStatus.Warning:
                    backColor = Color.FromArgb(255, 243, 224);
                    foreColor = Color.FromArgb(239, 108, 0);
                    borderColor = Color.FromArgb(255, 204, 128);
                    break;

                case BadgeStatus.Danger:
                    backColor = Color.FromArgb(253, 236, 234);
                    foreColor = Color.FromArgb(198, 40, 40);
                    borderColor = Color.FromArgb(239, 154, 154);
                    break;

                case BadgeStatus.Info:
                    backColor = Color.FromArgb(232, 240, 254);
                    foreColor = Color.FromArgb(25, 118, 210);
                    borderColor = Color.FromArgb(144, 202, 249);
                    break;

                default:
                    backColor = Color.FromArgb(240, 242, 245);
                    foreColor = Color.FromArgb(80, 80, 80);
                    borderColor = Color.FromArgb(210, 214, 220);
                    break;
            }

            panel1.BackColor = backColor;
            label1.ForeColor = foreColor;
            _borderColor = borderColor;
        }

        private Color _borderColor = Color.LightGray;
        private int _cornerRadius = 10;

        protected override void OnPaint(PaintEventArgs e)
        {
            base.OnPaint(e);

            e.Graphics.SmoothingMode = SmoothingMode.AntiAlias;

            using (GraphicsPath path = CreateRoundedRectanglePath(this.ClientRectangle, _cornerRadius))
            using (Pen pen = new Pen(_borderColor, 1))
            {
                this.Region = new Region(path);
                e.Graphics.DrawPath(pen, path);
            }
        }

        private GraphicsPath CreateRoundedRectanglePath(Rectangle rect, int radius)
        {
            GraphicsPath path = new GraphicsPath();

            int diameter = radius * 2;
            Rectangle arc = new Rectangle(rect.Location, new Size(diameter, diameter));

            path.AddArc(arc, 180, 90);
            arc.X = rect.Right - diameter - 1;
            path.AddArc(arc, 270, 90);
            arc.Y = rect.Bottom - diameter - 1;
            path.AddArc(arc, 0, 90);
            arc.X = rect.Left;
            path.AddArc(arc, 90, 90);
            path.CloseFigure();

            return path;
        }
    }
}
