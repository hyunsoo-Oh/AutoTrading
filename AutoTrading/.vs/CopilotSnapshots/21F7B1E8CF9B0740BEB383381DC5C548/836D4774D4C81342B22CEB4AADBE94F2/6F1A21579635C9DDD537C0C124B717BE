using System;
using System.ComponentModel;
using System.Drawing;
using System.Drawing.Drawing2D;
using System.Windows.Forms;

namespace AutoTrading.Controls.Cards
{
    public partial class ValueTrackerCard : UserControl
    {
        // ===== Appearance & Theme =====
        private Color _cardBackColor = Color.FromArgb(26, 28, 30);
        private Color _borderColor   = Color.FromArgb(40, 42, 45);
        private Color _titleColor    = Color.FromArgb(170, 170, 170);
        private Color _valueColor    = Color.White;
        private Color _upColor       = Color.FromArgb(72, 199, 142);
        private Color _downColor     = Color.FromArgb(229, 83, 80);
        private Color _subTextColor  = Color.FromArgb(130, 130, 130);
        private int   _cornerRadius  = 8;

        // ===== Data & State =====
        private decimal _totalValue   = 0m;
        private decimal _changeAmount = 0m;
        private float   _changeRate   = 0f;
        private bool    _isPositive   = false;
        private string  _valueFormat  = "N0";

        // ===== Behavior & Layout =====
        private bool   _showIndicator = true;
        private string _titleText     = "총 자산 가치";

        public ValueTrackerCard()
        {
            InitializeComponent();
            SetStyle(
                ControlStyles.AllPaintingInWmPaint |
                ControlStyles.UserPaint |
                ControlStyles.ResizeRedraw |
                ControlStyles.OptimizedDoubleBuffer, true);
            DoubleBuffered = true;
            Size    = new Size(250, 100);
            Padding = new Padding(15, 10, 15, 10);
            BackColor = Color.Transparent;
        }

        // ===== Appearance & Theme =====

        [Category("Appearance")]
        public Color CardBackColor
        {
            get => _cardBackColor;
            set { _cardBackColor = value; Invalidate(); }
        }

        [Category("Appearance")]
        public Color BorderColor
        {
            get => _borderColor;
            set { _borderColor = value; Invalidate(); }
        }

        [Category("Appearance")]
        public Color TitleColor
        {
            get => _titleColor;
            set { _titleColor = value; Invalidate(); }
        }

        [Category("Appearance")]
        public Color ValueColor
        {
            get => _valueColor;
            set { _valueColor = value; Invalidate(); }
        }

        [Category("Appearance")]
        public Color UpColor
        {
            get => _upColor;
            set { _upColor = value; Invalidate(); }
        }

        [Category("Appearance")]
        public Color DownColor
        {
            get => _downColor;
            set { _downColor = value; Invalidate(); }
        }

        [Category("Appearance")]
        public int CornerRadius
        {
            get => _cornerRadius;
            set { _cornerRadius = Math.Max(0, value); Invalidate(); }
        }

        // ===== Data & State =====

        [Category("Data & State")]
        public decimal TotalValue
        {
            get => _totalValue;
            set { _totalValue = value; Invalidate(); }
        }

        /// <summary>변경 시 IsPositive 와 ChangeRate 를 자동 계산합니다.</summary>
        [Category("Data & State")]
        public decimal ChangeAmount
        {
            get => _changeAmount;
            set
            {
                _changeAmount = value;

                // ── IsPositive 자동 계산 ──
                _isPositive = value >= 0;

                // ── ChangeRate 자동 계산 (전일가 = TotalValue - ChangeAmount) ──
                decimal prevValue = _totalValue - value;
                _changeRate = prevValue != 0
                    ? (float)(Math.Abs(value) / Math.Abs(prevValue) * 100m)
                    : 0f;

                Invalidate();
            }
        }

        [Category("Data & State")]
        public float ChangeRate
        {
            get => _changeRate;
            set { _changeRate = value; Invalidate(); }
        }

        [Category("Data & State")]
        public bool IsPositive
        {
            get => _isPositive;
            set { _isPositive = value; Invalidate(); }
        }

        /// <summary>금액 표시 포맷 (예: N0, N2, C0)</summary>
        [Category("Data & State")]
        public string ValueFormat
        {
            get => _valueFormat;
            set { _valueFormat = value; Invalidate(); }
        }

        // ===== Behavior & Layout =====

        [Category("Behavior & Layout")]
        public bool ShowIndicator
        {
            get => _showIndicator;
            set { _showIndicator = value; Invalidate(); }
        }

        [Category("Behavior & Layout")]
        public string TitleText
        {
            get => _titleText;
            set { _titleText = value; Invalidate(); }
        }

        // ===== Helpers =====

        private Color ThemeColor => _isPositive ? _upColor : _downColor;

        // ===== Paint =====

        protected override void OnPaint(PaintEventArgs e)
        {
            base.OnPaint(e);
            var g = e.Graphics;
            g.SmoothingMode = SmoothingMode.AntiAlias;
            g.TextRenderingHint = System.Drawing.Text.TextRenderingHint.ClearTypeGridFit;

            DrawBackground(g);

            using var titleFont = new Font("Segoe UI", 9f, FontStyle.Bold);
            using var valueFont = new Font("Segoe UI", 16f, FontStyle.Bold);
            using var sf        = StringFormat.GenericTypographic;

            // ===== 행 간격 변경 =====
            const float ROW_GAP = 12f;
            // ========================

            float titleY     = Padding.Top;
            float titleH     = g.MeasureString("A", titleFont, PointF.Empty, sf).Height;
            float valueY     = titleY + titleH + ROW_GAP;
            float valueH     = g.MeasureString("A", valueFont, PointF.Empty, sf).Height;
            float indicatorY = valueY + valueH + ROW_GAP;

            DrawTitle(g, titleFont, titleY);
            DrawValue(g, valueFont, valueY);
            if (_showIndicator)
                DrawIndicator(g, indicatorY);
        }

        private void DrawBackground(Graphics g)
        {
            var rect = new Rectangle(0, 0, Width - 1, Height - 1);
            using var path   = CreateRoundRect(rect, _cornerRadius);
            using var fill   = new SolidBrush(_cardBackColor);
            using var border = new Pen(_borderColor, 1.5f);
            g.FillPath(fill, path);
            g.DrawPath(border, path);
        }

        private void DrawTitle(Graphics g, Font font, float y)
        {
            using var brush = new SolidBrush(_titleColor);
            g.DrawString(_titleText, font, brush, Padding.Left, y);
        }

        private void DrawValue(Graphics g, Font font, float y)
        {
            using var brush = new SolidBrush(_valueColor);
            g.DrawString(_totalValue.ToString(_valueFormat), font, brush, Padding.Left, y);
        }

        private void DrawIndicator(Graphics g, float ty)
        {
            // ===== 열 간격 변경 =====
            const float COL_GAP   = 8f;   // 요소 사이 간격 (px)
            const int   ARROW_W   = 8;    // 화살표 너비 (px)
            const int   ARROW_H   = 6;    // 화살표 높이 (px)
            // ========================

            float x = Padding.Left;
            Color theme = ThemeColor;

            using var font      = new Font("Segoe UI", 9f, FontStyle.Bold);
            using var subFont   = new Font("Segoe UI", 9f, FontStyle.Regular);
            using var sf        = StringFormat.GenericTypographic;
            using var themeBrush = new SolidBrush(theme);
            using var subBrush  = new SolidBrush(_subTextColor);

            float textH  = g.MeasureString("A", font, PointF.Empty, sf).Height;
            int   arrowY = (int)(ty + (textH - ARROW_H) / 2f);

            // ── ▲/▼ 화살표 ──
            DrawSmallArrow(g, themeBrush, (int)x, arrowY, _isPositive);
            x += ARROW_W + COL_GAP;

            // ── 변동 금액 ──
            string amountText = Math.Abs(_changeAmount).ToString(_valueFormat);
            g.DrawString(amountText, font, themeBrush, x, ty);
            x += g.MeasureString(amountText, font, PointF.Empty, sf).Width + COL_GAP;

            // ── "(" ──
            g.DrawString("  (", subFont, subBrush, x, ty);
            x += g.MeasureString("(", subFont, PointF.Empty, sf).Width + COL_GAP + 8;

            // ── ▲/▼ 화살표 (변동률 앞) ──
            DrawSmallArrow(g, themeBrush, (int)x, arrowY, _isPositive);
            x += ARROW_W + COL_GAP;

            // ── 변동률 ──
            string rateText = $"{Math.Abs(_changeRate):N2}%";
            g.DrawString(rateText, font, themeBrush, x, ty);
            x += g.MeasureString(rateText, font, PointF.Empty, sf).Width + 2f;

            // ── ")" ──
            g.DrawString(")", subFont, subBrush, x, ty);
        }

        /// <summary>상승(▲) / 하락(▼) 소형 삼角형 — 8×6 px</summary>
        private static void DrawSmallArrow(Graphics g, Brush brush, int x, int y, bool up)
        {
            Point[] pts = up
                ? new[] { new Point(x, y + 6), new Point(x + 4, y),     new Point(x + 8, y + 6) }
                : new[] { new Point(x, y),     new Point(x + 8, y),     new Point(x + 4, y + 6) };
            g.FillPolygon(brush, pts);
        }

        private static GraphicsPath CreateRoundRect(Rectangle rect, int radius)
        {
            var path = new GraphicsPath();
            int d = Math.Max(1, radius * 2);
            path.AddArc(rect.X,         rect.Y,          d, d, 180, 90);
            path.AddArc(rect.Right - d, rect.Y,          d, d, 270, 90);
            path.AddArc(rect.Right - d, rect.Bottom - d, d, d,   0, 90);
            path.AddArc(rect.X,         rect.Bottom - d, d, d,  90, 90);
            path.CloseFigure();
            return path;
        }
    }
}
