using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace AutoTrading.Controls.Cards
{
    /// <summary>
    /// ChartCard 컨트롤의 색상/레이아웃 스타일 설정
    /// </summary>
    public class CardStyle
    {
        /// <summary>카드 배경 색상</summary>
        public Color CardBackColor { get; set; } = Color.FromArgb(26, 28, 30);   // StockCard 기준 Charcoal
        /// <summary>제목 텍스트 색상</summary>
        public Color TitleColor { get; set; } = Color.FromArgb(170, 170, 170); // Mid Gray
        /// <summary>값 텍스트 색상</summary>
        public Color ValueColor { get; set; } = Color.White;

        /// <summary>변동 뱃지 배경 색상</summary>
        public Color BadgeBackColor { get; set; } = Color.FromArgb(36, 38, 40);
        /// <summary>상승 시 색상</summary>
        public Color UpColor { get; set; } = Color.FromArgb(72, 199, 142);  // Spring Green
        /// <summary>하락 시 색상</summary>
        public Color DownColor { get; set; } = Color.FromArgb(229, 83, 80);   // Vivid Red
        /// <summary>보합 시 색상</summary>
        public Color FlatColor { get; set; } = Color.FromArgb(144, 164, 174); // Cool Gray

        /// <summary>차트 상승 선 색상</summary>
        public Color ChartUpColor { get; set; } = Color.FromArgb(72, 199, 142);
        /// <summary>차트 하락 선 색상</summary>
        public Color ChartDownColor { get; set; } = Color.FromArgb(229, 83, 80);
        /// <summary>차트 보합 선 색상</summary>
        public Color ChartFlatColor { get; set; } = Color.FromArgb(144, 156, 164);

        /// <summary>시간 라벨 색상</summary>
        public Color TimeLabelColor { get; set; } = Color.FromArgb(120, 170, 170, 170);

        /// <summary>카드 모서리 둥글기 (px)</summary>
        public int CornerRadius { get; set; } = 24;
        /// <summary>카드 내부 여백 (px)</summary>
        public int PaddingSize { get; set; } = 18;
        /// <summary>헤더 상단 여백 (px)</summary>
        public int HeaderTop { get; set; } = 18;
        /// <summary>차트 영역 높이 (px)</summary>
        public int ChartHeight { get; set; } = 95;
    }
}
