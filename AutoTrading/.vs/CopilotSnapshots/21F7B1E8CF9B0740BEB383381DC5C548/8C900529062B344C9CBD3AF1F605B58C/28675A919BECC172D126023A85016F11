using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace AutoTrading.Presentation.Models.Market
{
    /// <summary>
    /// 종목 기본 정보 모델 (종목코드, 종목명)
    /// </summary>
    public class StockBaseInfo
    {
        private string _itemCode;
        private string _itemName;

        /// <summary>
        /// 종목코드와 종목명을 지정하여 생성
        /// </summary>
        public StockBaseInfo(string itemCode, string itemName)
        {
            _itemCode = itemCode;
            _itemName = itemName;
        }

        /// <summary>종목코드 (예: 005930)</summary>
        public string ItemCode
        {
            get => _itemCode;
            set
            {
                _itemCode = value;
                //OnPropertyChanged(nameof(ItemCode));
            }
        }

        /// <summary>종목명 (예: 삼성전자)</summary>
        public string ItemName
        {
            get => _itemName;
            set
            {
                _itemName = value;
                //OnPropertyChanged(nameof(ItemName));
            }
        }
    }
}
