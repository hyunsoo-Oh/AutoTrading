using AutoTrading.Configuration;
using AutoTrading.Features.Models.Api.Accounts;
using AutoTrading.Features.Models.Api.Auth;
using AutoTrading.Features.Models.Api.Orders;
using AutoTrading.Features.Views.Interfaces;
using AutoTrading.Services.KoreaInvest.Accounts;
using AutoTrading.Services.KoreaInvest.Auth;
using AutoTrading.Services.KoreaInvest.Common;
using AutoTrading.Services.KoreaInvest.Common.Http;
using AutoTrading.Services.KoreaInvest.Orders;
using System.Diagnostics;

namespace AutoTrading.Features.Presenters.Main
{
    /// <summary>
    /// MainForm의 비즈니스 로직을 담당하는 Presenter
    ///
    /// 왜 Presenter로 분리하는가?
    /// - MainForm에 토큰 발급, 환경 전환, 잔고 조회 로직이 직접 들어 있으면
    ///   화면 코드와 비즈니스 로직이 섞여 유지보수가 어렵다.
    /// - Presenter는 View 인터페이스(IMainView)만 알고, 구체적 컨트롤은 모른다.
    /// - 나중에 테스트할 때 IMainView를 Mock으로 교체하면 UI 없이도 로직 검증 가능.
    ///
    /// 수정 포인트:
    /// - 새 비즈니스 동작 추가 시 이 클래스에 메서드를 추가한다.
    /// - UI 동작이 필요하면 IMainView에 메서드를 추가하고 Presenter에서 호출한다.
    /// </summary>
    public class MainPresenter : IDisposable
    {
        /// <summary>View 인터페이스 ? UI 갱신 시 이 인터페이스를 통해 호출</summary>
        private readonly IMainView _view;
        /// <summary>인증 서비스 ? 토큰 발급/갱신 담당</summary>
        private readonly IAuthService _authService;
        /// <summary>API 설정 (Mock/Live 접속 정보)</summary>
        private readonly ApiSettings _apiSettings;
        /// <summary>현재 거래 환경 관리 서비스</summary>
        private readonly IKisTradingService _kisTradingService;

        /// <summary>HTTP 통신 전담 객체</summary>
        private HttpClient? _httpClient;

        /// <summary>계좌 조회 서비스</summary>
        private IAccountService? _accountService;
        /// <summary>주문 서비스</summary>
        private IOrderService _orderService;

        // ===== 토큰 발급에 성공한 환경 목록 =====
        // 최초에는 Live만 들어 있고, 사용자가 Mock 전환에 성공하면 Mock도 추가된다.
        // 타이머는 이 목록에 있는 환경만 주기적으로 갱신한다.
        // ===== =====
        private readonly HashSet<KisTradingMode> _authenticatedModes = new();

        /// <summary>
        /// Presenter 생성 View와 서비스들을 주입받는다
        /// </summary>
        public MainPresenter(
            IMainView view,
            IAuthService authService,
            ApiSettings apiSettings,
            IKisTradingService kisTradingService)
        {
            _view = view;
            _authService = authService;
            _apiSettings = apiSettings;
            _kisTradingService = kisTradingService;
        }

        /// <summary>
        /// 앱 시작 시 호출 — 서비스 초기화 및 현재 환경 토큰만 발급
        ///
        /// 왜 현재 환경만?
        /// - 실전투자로 시작할 때 모의투자 토큰까지 동시에 발급하면
        ///   한국투자증권의 토큰 발급 횟수 제한에 걸릴 수 있다.
        /// - 모의투자 토큰은 사용자가 메뉴에서 전환할 때 최초 1회만 발급한다.
        /// </summary>
        public async Task InitializeAsync()
        {
            RebuildServices();

            // ===== 현재 환경(실전투자) 토큰만 발급 =====
            bool success = await TryAuthenticateCurrentModeAsync();
            if (success)
            {
                _authenticatedModes.Add(_kisTradingService.CurrentEnvironment);
            }

            await RefreshTokenAsync();
        }

        /// <summary>
        /// 서비스 객체 생성/재생성
        /// </summary>
        private void RebuildServices()
        {
            _httpClient?.Dispose();
            _httpClient = new HttpClient();

            _accountService = new KisAccountService(_httpClient, _kisTradingService, _authService);
            _orderService = new KisOrderService(_httpClient, _kisTradingService, _authService);
        }

        /// <summary>
        /// 현재 환경의 토큰 발급을 시도하고 성공 여부를 반환한다.
        /// View 갱신 없이 순수하게 토큰만 확인한다.
        /// </summary>
        private async Task<bool> TryAuthenticateCurrentModeAsync()
        {
            try
            {
                TokenResponse? token = await _authService.GetAccessTokenAsync();
                return token != null && !string.IsNullOrWhiteSpace(token.AccessToken);
            }
            catch
            {
                return false;
            }
        }

        /// <summary>
        /// 현재 환경의 토큰 발급/갱신 후 View 연결 상태 갱신
        /// </summary>
        public async Task RefreshTokenAsync()
        {
            try
            {
                TokenResponse? token = await _authService.GetAccessTokenAsync();

                bool connected = token != null && !string.IsNullOrWhiteSpace(token.AccessToken);
                string accountInfo = _kisTradingService.GetCurrentSettings().AccountNumber;
                _view.UpdateConnectionStatus(connected, accountInfo);

                Console.WriteLine(connected
                    ? $"[TOKEN] 발급/갱신 성공 | 만료: {token!.AccessTokenExpired}"
                    : "[TOKEN] 발급 실패: 토큰이 비어 있음");
            }
            catch (Exception ex)
            {
                _view.UpdateConnectionStatus(false, "");
                Console.WriteLine($"[TOKEN] 발급 실패: {ex.Message}");
                _view.ShowErrorMessage($"토큰 요청 실패: {ex.Message}", "인증 오류");
            }
        }

        /// <summary>
        /// 인증된 환경의 토큰만 주기적으로 갱신 — 타이머에서 호출
        ///
        /// 왜 인증된 환경만?
        /// - 아직 토큰을 받은 적이 없는 환경까지 갱신하면
        ///   불필요한 API 호출이 발생하고, 실패 시 에러 로그가 쌓인다.
        /// - 사용자가 한 번이라도 전환에 성공한 환경만 갱신 대상이다.
        /// </summary>
        public async Task RefreshAllTokensAsync()
        {
            KisTradingMode current = _kisTradingService.CurrentEnvironment;

            // ===== 인증된 환경의 토큰을 조용히 갱신 =====
            // 현재 활성 환경이 아닌 모드는 View 갱신 없이 갱신한다.
            foreach (KisTradingMode mode in _authenticatedModes)
            {
                _kisTradingService.SetEnvironment(mode);

                try
                {
                    await _authService.GetAccessTokenAsync();
                    Console.WriteLine($"[TOKEN] {mode} 토큰 갱신 성공");
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"[TOKEN] {mode} 토큰 갱신 실패: {ex.Message}");
                }
            }

            // ===== 현재 환경으로 복원 후 View 연결 상태 갱신 =====
            _kisTradingService.SetEnvironment(current);
            await RefreshTokenAsync();
        }

        /// <summary>
        /// 거래 환경 전환 (Mock ↔ Live)
        ///
        /// 왜 토큰을 먼저 확인하는가?
        /// - 전환 대상 환경의 토큰이 아직 없으면 API 호출이 불가능하다.
        /// - 토큰 발급이 실패하면 전환하지 않고 현재 환경을 유지한다.
        /// - 한 번 토큰 발급에 성공하면 _authenticatedModes에 추가되어
        ///   이후 전환은 즉시 이루어지고, 타이머가 자동 갱신한다.
        /// </summary>
        /// <param name="mode">전환할 거래 모드</param>
        public async Task SwitchEnvironmentAsync(KisTradingMode mode)
        {
            if (_kisTradingService.CurrentEnvironment == mode)
            {
                Console.WriteLine($"[ENV] 이미 {mode} 환경입니다.");
                return;
            }

            string modeText = mode == KisTradingMode.Live ? "실전투자" : "모의투자";
            KisTradingMode originalMode = _kisTradingService.CurrentEnvironment;

            // ===== 전환 대상 환경의 토큰 확보 =====
            // 아직 토큰을 받은 적이 없는 환경이면 먼저 발급을 시도한다.
            // SetEnvironment(이벤트 없음)로 임시 전환 후 토큰 발급을 시도한다.
            if (!_authenticatedModes.Contains(mode))
            {
                _kisTradingService.SetEnvironment(mode);

                bool success = await TryAuthenticateCurrentModeAsync();

                if (!success)
                {
                    // ===== 토큰 발급 실패 → 원래 환경으로 복원 =====
                    _kisTradingService.SetEnvironment(originalMode);
                    Console.WriteLine($"[ENV] {mode} 토큰 발급 실패 — 전환 취소");
                    _view.ShowErrorMessage(
                        $"{modeText} 토큰 발급에 실패하여 전환할 수 없습니다.\n" +
                        $"appsettings.json의 {mode} AppKey/AppSecret을 확인하세요.",
                        "환경 전환 실패");
                    return;
                }

                _authenticatedModes.Add(mode);
                Console.WriteLine($"[ENV] {mode} 토큰 최초 발급 성공");
            }

            // ===== 환경 전환 + EnvironmentChanged 이벤트 발생 =====
            // DashboardPresenter 등 구독자가 즉시 갱신된다.
            _kisTradingService.SwitchEnvironment(mode);
            _view.UpdateTradingModeDisplay(modeText);

            // ===== 전환 후 View 연결 상태 갱신 =====
            await RefreshTokenAsync();

            Console.WriteLine($"[ENV] 환경 전환 완료: {mode}");
        }

        /// <summary>
        /// 주식잔고조회 API 호출 후 결과를 View에 전달
        /// </summary>
        public async Task InquireBalanceAsync()
        {
            if (_accountService == null)
            {
                _view.ShowErrorMessage("계좌 서비스가 초기화되지 않았습니다.", "오류");
                return;
            }

            try
            {
                KisTradingMode mode = _kisTradingService.CurrentEnvironment;
                ApiEndpointSettings currentSettings = _kisTradingService.GetCurrentSettings();

                var request = new InquireBalanceRequest
                {
                    CANO = currentSettings.AccountNumber,
                    ACNT_PRDT_CD = InquireBalanceAccountProductCodeProvider.Get(mode),
                    AFHR_FLPR_YN = "N",
                    OFL_YN = "",
                    INQR_DVSN = "01",
                    UNPR_DVSN = "01",
                    FUND_STTL_ICLD_YN = "N",
                    FNCG_AMT_AUTO_RDPT_YN = "N",
                    PRCS_DVSN = "00",
                    CTX_AREA_FK100 = "",
                    CTX_AREA_NK100 = ""
                };

                InquireBalanceResponse? response =
                    await _accountService.InquireBalanceAsync(request);

                if (response == null)
                {
                    _view.ShowErrorMessage("응답이 null 입니다.", "잔고 조회");
                    return;
                }

                Console.WriteLine($"RtCd: {response.RtCd}");
                Console.WriteLine($"MsgCd: {response.MsgCd}");
                Console.WriteLine($"Msg1: {response.Msg1}");
                Console.WriteLine($"보유 종목 수: {response.Output1?.Count ?? 0}");

                if (response.Output2 != null && response.Output2.Count > 0)
                {
                    var summary = response.Output2[0];
                    Console.WriteLine($"예수금: {summary.DepositTotalAmount}");
                    Console.WriteLine($"총평가금액: {summary.TotalEvaluationAmount}");
                    Console.WriteLine($"순자산금액: {summary.NetAssetAmount}");
                }

                _view.ShowInfoMessage("주식잔고조회 테스트 완료", "잔고 조회");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"오류: {ex.Message}");
                _view.ShowErrorMessage(ex.ToString(), "주식잔고조회 테스트 실패");
            }
        }

        /// <summary>
        /// 삼성전자(005930) 테스트 주문
        /// 왜 별도 메서드로 분리하는가?
        /// - Buy / Sell 버튼이 같은 흐름을 공유하기 때문이다.
        /// - 버튼 이벤트 안에 주문 생성/호출/결과 처리까지 다 넣으면 길어지고 유지보수가 어려워진다.
        /// </summary>
        public async Task SendSamsungTestOrderAsync(OrderSide orderSide)
        {
            // ===== 수정 포인트 =====
            // 실제 Form에서 관리하는 계좌번호 필드명으로 맞춰서 사용하면 된다.
            string accountNo = _kisTradingService.GetCurrentSettings().AccountNumber;

            if (string.IsNullOrWhiteSpace(accountNo))
            {
                MessageBox.Show("계좌번호가 선택되지 않았습니다.");
                return;
            }

            // ===== 테스트용 주문 요청 =====
            OrderCashRequest request = new OrderCashRequest
            {
                Cano = accountNo.Trim(),     // 계좌번호 8자리
                AcntPrdtCd = "01",           // 보통 01
                PdNo = "005930",             // 삼성전자
                SllType = "01",              // 일반매도
                OrdDvsn = "01",              // 01 = 시장가
                OrdQty = "1",                // 1주
                OrdUnpr = "0",               // 시장가 주문은 0
                CndtPric = "0",
                ExcgIdDvsnCd = "KRX"
            };

            // ===== 주문 요청 =====
            OrderCashResponse response = await _orderService.OrderCashAsync(request, orderSide);

            // ===== 결과 메시지 구성 =====
            string orderTypeText = orderSide == OrderSide.Buy ? "매수" : "매도";
            string orderNo = response.Output?.Odno ?? "(주문번호 없음)";
            string orderTime = response.Output?.OrdTmd ?? "(주문시간 없음)";

            string message =
                $"[{orderTypeText} 테스트 주문 완료]\r\n" +
                $"종목: 삼성전자(005930)\r\n" +
                $"수량: 1주\r\n" +
                $"주문구분: 시장가\r\n" +
                $"rt_cd: {response.RtCd}\r\n" +
                $"msg_cd: {response.MsgCd}\r\n" +
                $"msg1: {response.Msg1}\r\n" +
                $"주문번호: {orderNo}\r\n" +
                $"주문시간: {orderTime}";

            MessageBox.Show(
                message,
                $"{orderTypeText} 테스트",
                MessageBoxButtons.OK,
                MessageBoxIcon.Information);

            Console.WriteLine(message);
        }
        public void Dispose()
        {
            _httpClient?.Dispose();
        }
    }
}
