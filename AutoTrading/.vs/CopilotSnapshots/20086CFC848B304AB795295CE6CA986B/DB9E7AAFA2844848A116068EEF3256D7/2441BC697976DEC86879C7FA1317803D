        private void MainForm_Load(object sender, EventArgs e)
        {
            InitClockTimer();
            InitNavigationBar();

            // ===== Presenter 초기화 위임 =====
            // 서비스 생성, 토큰 발급 등 비즈니스 로직은 Presenter가 처리한다.
            // ===== =====
            _ = InitAsync();
        }

        private async Task InitAsync()
        {
            if (_presenter == null) return;

            await _presenter.InitializeAsync();

            // ===== 토큰 주기 갱신 타이머 =====
            // 타이머 자체는 UI 인프라이므로 Form이 관리한다.
            // 타이머 Tick에서 Presenter에 갱신을 위임한다.
            // ===== =====
            _tokenRefreshTimer = new System.Windows.Forms.Timer();
            _tokenRefreshTimer.Interval = TokenRefreshIntervalMs;
            _tokenRefreshTimer.Tick += async (s, e) =>
            {
                if (_presenter != null)
                    await _presenter.RefreshAllTokensAsync();
            };
            _tokenRefreshTimer.Start();
        }

        private void MainForm_Shown(object sender, EventArgs e)
        {
        }

        // ===== 시계 타이머 =====
        // 순수 UI 기능이므로 Form이 직접 처리한다.
        // ===== =====
        private void InitClockTimer()
        {
            _clockTimer = new System.Windows.Forms.Timer();
            _clockTimer.Interval = 1000;
            _clockTimer.Tick += (s, e) =>
            {
                toolStripStatusLabel_Clock.Text = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss");
                if (DateTime.Now.ToString("HH: mm:ss") == "09:02:02")
                {
                    _presenter.SendSamsungTestOrderAsync(OrderSide.Buy).Wait();
                }
            };
            _clockTimer?.Start();
        }

