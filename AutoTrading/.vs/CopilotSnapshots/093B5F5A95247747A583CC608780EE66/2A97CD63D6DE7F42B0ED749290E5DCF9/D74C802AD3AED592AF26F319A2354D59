namespace AutoTrading.Controls.Shell.TobBar
{
    public partial class TwoLineTopBar : UserControl
    {
        private readonly System.Windows.Forms.Timer _clockTimer = new();
        private bool _isServerConnected;

        public TwoLineTopBar()
        {
            InitializeComponent();

            _clockTimer.Interval = 1000;
            _clockTimer.Tick += (_, _) =>
            {
                if (UseRealtimeClock)
                {
                    ClockText = DateTime.Now.ToString(ClockFormat);
                }
            };

            if (!DesignMode)
            {
                _clockTimer.Start();
            }

            ClockText = DateTime.Now.ToString(ClockFormat);
            UpdateConnectionUi();
            UpdateAccountUi();
        }

        [Category("TopBar")]
        [Description("모의투자/실전투자 라벨 텍스트")]
        public string InvestmentMode
        {
            get => label_Server.Text;
            set => label_Server.Text = value;
        }

        [Category("TopBar")]
        [Description("서버 연결 상태")]
        public bool IsServerConnected
        {
            get => _isServerConnected;
            set
            {
                _isServerConnected = value;
                UpdateConnectionUi();
            }
        }

        [Category("TopBar")]
        [Description("서버 연결 상태 텍스트")]
        public string ConnectedText { get; set; } = "서버 연결됨";

        [Category("TopBar")]
        [Description("서버 해제 상태 텍스트")]
        public string DisconnectedText { get; set; } = "서버 연결 해제";

        [Category("TopBar")]
        [Description("표시할 계좌번호")]
        public string AccountNumber { get; set; } = string.Empty;

        [Category("TopBar")]
        [Description("계좌번호 라벨 앞 텍스트")]
        public string AccountPrefix { get; set; } = "계좌번호:";

        [Category("TopBar")]
        [Description("실시간 시계 사용 여부")]
        public bool UseRealtimeClock { get; set; } = true;

        [Category("TopBar")]
        [Description("시계 표시 포맷")]
        public string ClockFormat { get; set; } = "HH:mm:ss";

        [Browsable(false)]
        public string ClockText
        {
            get => label_Clock.Text;
            private set => label_Clock.Text = value;
        }

        public void SetAccountNumber(string accountNo)
        {
            AccountNumber = accountNo;
            UpdateAccountUi();
        }

        private void UpdateConnectionUi()
        {
            statusLabel.Status = _isServerConnected
                ? StatusLabel.StatusEnum.Green
                : StatusLabel.StatusEnum.Gray;

            statusLabel.StatusText = _isServerConnected
                ? ConnectedText
                : DisconnectedText;
        }

        private void UpdateAccountUi()
        {
            label_Account.Text = string.IsNullOrWhiteSpace(AccountNumber)
                ? $"{AccountPrefix}"
                : $"{AccountPrefix} {AccountNumber}";
        }

        protected override void Dispose(bool disposing)
        {
            if (disposing)
            {
                _clockTimer.Stop();
                _clockTimer.Dispose();
            }

            base.Dispose(disposing);
        }
    }
}
