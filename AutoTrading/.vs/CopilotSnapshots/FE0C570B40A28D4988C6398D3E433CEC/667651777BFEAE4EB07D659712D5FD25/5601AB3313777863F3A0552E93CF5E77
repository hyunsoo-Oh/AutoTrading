_realtimeService.CcnlNotifyReceived += (s, data) =>
{
    string type = data.CntgYn == "2" ? "체결" : "접수";
    Console.WriteLine($"[{type}] {data.StckShrnIscd} 주문:{data.OderNo} 체결:{data.CntgQty}주 @{data.CntgUnpr}원");
};
await _realtimeService.SubscribeCcnlNotifyAsync("myHtsId");

// 해제
await _realtimeService.UnsubscribeCcnlNotifyAsync("myHtsId");
await _realtimeService.DisconnectAsync();
```

