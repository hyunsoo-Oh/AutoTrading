using System.Text.Json.Serialization;

namespace KisRestAPI.Models.Auth
{
    // =====================================================================
    // ===== 토큰 발급 요청 DTO =====
    // =====================================================================

    public class TokenRequest
    {
        [JsonPropertyName("grant_type")]
        public string GrantType { get; set; } = "client_credentials";

        [JsonPropertyName("appkey")]
        public string AppKey { get; set; } = string.Empty;

        [JsonPropertyName("appsecret")]
        public string AppSecret { get; set; } = string.Empty;
    }

    // =====================================================================
    // ===== 토큰 발급 응답 DTO =====
    // System.Text.Json의 PropertyNameCaseInsensitive=true 설정만으로는
    // snake_case ↔ PascalCase 변환이 되지 않으므로
    // [JsonPropertyName]으로 정확한 JSON 키를 명시해야 올바르게 역직렬화된다.
    // =====================================================================

    public class TokenResponse
    {
        /// <summary>발급된 접근 토큰</summary>
        [JsonPropertyName("access_token")]
        public string AccessToken { get; set; } = string.Empty;

        /// <summary>토큰 타입 (Bearer)</summary>
        [JsonPropertyName("token_type")]
        public string TokenType { get; set; } = string.Empty;

        /// <summary>토큰 유효 시간 (초)</summary>
        [JsonPropertyName("expires_in")]
        public double ExpiresIn { get; set; }

        /// <summary>토큰 만료 일시 문자열</summary>
        [JsonPropertyName("access_token_token_expired")]
        public string AccessTokenExpired { get; set; } = string.Empty;
    }

    // =====================================================================
    // ===== HashKey 발급 응답 DTO =====
    // =====================================================================

    public class HashKeyResponse
    {
        [JsonPropertyName("HASH")]
        public string Hash { get; set; } = string.Empty;
    }

    // =====================================================================
    // ===== WebSocket Approval Key 발급 요청 DTO =====
    // POST /oauth2/Approval
    // =====================================================================

    public class ApprovalKeyRequest
    {
        [JsonPropertyName("grant_type")]
        public string GrantType { get; set; } = "client_credentials";

        [JsonPropertyName("appkey")]
        public string AppKey { get; set; } = string.Empty;

        /// <summary>주의: 토큰 발급 API의 "appsecret"과 달리 "secretkey"를 사용한다</summary>
        [JsonPropertyName("secretkey")]
        public string SecretKey { get; set; } = string.Empty;
    }

    // =====================================================================
    // ===== WebSocket Approval Key 발급 응답 DTO =====
    // =====================================================================

    public class ApprovalKeyResponse
    {
        [JsonPropertyName("approval_key")]
        public string ApprovalKey { get; set; } = string.Empty;
    }

    // =====================================================================
    // ===== 한국투자증권 API 에러 응답 DTO =====
    // =====================================================================

    public class KisErrorResponse
    {
        [JsonPropertyName("error_code")]
        public string ErrorCode { get; set; } = string.Empty;

        [JsonPropertyName("error_description")]
        public string ErrorDescription { get; set; } = string.Empty;

        [JsonPropertyName("msg1")]
        public string Message1 { get; set; } = string.Empty;

        [JsonPropertyName("msg_cd")]
        public string MessageCode { get; set; } = string.Empty;
    }
}
