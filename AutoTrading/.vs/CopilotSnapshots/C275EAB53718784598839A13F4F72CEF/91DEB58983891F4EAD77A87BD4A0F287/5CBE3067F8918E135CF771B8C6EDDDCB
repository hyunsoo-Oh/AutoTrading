using AutoTrading.Configuration;
using AutoTrading.Features.Presenters.Main;
using AutoTrading.Features.Views.Contents;
using AutoTrading.Features.Views.Forms;
using AutoTrading.Services.KoreaInvest.Auth;
using AutoTrading.Services.KoreaInvest.Common;
using Microsoft.Extensions.Configuration;

namespace AutoTrading
{
    internal static class Program
    {
        /// <summary>
        ///  The main entry point for the application.
        /// </summary>
        [STAThread]
        static void Main()
        {
            ApplicationConfiguration.Initialize();

            // ===== Configuration =====
            IConfiguration config = new ConfigurationBuilder()
                .SetBasePath(AppContext.BaseDirectory)
                .AddJsonFile("appsettings.json", optional: false, reloadOnChange: true)
                .Build();

            var apiSettings = config.GetSection("ApiSettings").Get<ApiSettings>();
            if (apiSettings == null)
            {
                MessageBox.Show("ApiSettings 설정 로드 실패", "오류");
                return;
            }

            var tradingMode = apiSettings.TradingMode.Equals("Live", StringComparison.OrdinalIgnoreCase)
                ? KiaTradingMode.Live
                : KiaTradingMode.Mock;

            // ===== Services 생성 =====
            var kiaTradingService = new KiaTradingService(apiSettings);
            kiaTradingService.SetEnvironment(tradingMode);

            var httpClient = new HttpClient();
            var authService = new KiaAuthService(httpClient, apiSettings, kiaTradingService);

            // ===== Views 생성 =====
            var mainForm = new MainForm();
            var settingsForm = new SettingsForm();

            var contentViews = new Dictionary<string, UserControl>
            {
                ["Dashboard"] = new Dashboard(authService, apiSettings, kiaTradingService),
                ["Market"]    = new MarketRegime(),
                ["Asset"]     = new Asset(),
                ["Orders"]    = new Orders(),
                ["Strategy"]  = new Strategy(),
                ["Report"]    = new Report(),
                ["Backtest"]  = new Backtest(),
                ["Logging"]   = new Logging(),
            };

            mainForm.RegisterContentViews(contentViews);
            mainForm.RegisterSettingsForm(settingsForm);

            string modeText = tradingMode == KiaTradingMode.Mock ? "모의투자" : "실전투자";
            mainForm.UpdateTradingModeDisplay(modeText);

            // ===== Presenters 생성 =====
            var mainPresenter = new MainPresenter(mainForm, authService, apiSettings, kiaTradingService);
            mainForm.SetPresenter(mainPresenter);

            // ===== 프로그램 종료 시 =====
            mainForm.FormClosed += (s, e) =>
            {
                mainPresenter.Dispose();
                httpClient.Dispose();
            };

            // ===== 화면 실행 =====
            Application.Run(mainForm);
        }
    }
}