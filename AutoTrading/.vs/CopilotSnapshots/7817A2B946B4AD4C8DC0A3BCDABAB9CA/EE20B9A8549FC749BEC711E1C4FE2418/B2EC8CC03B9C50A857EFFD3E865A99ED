using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace AutoTrading.Controls.Cards
{
    public class CardStyle
    {
        // [Category: Appearance - Colors]

        // 카드 및 배경 (Deep Midnight Navy)
        public Color CardBackColor { get; set; } = Color.FromArgb(10, 20, 45);
        public Color TitleColor { get; set; } = Color.FromArgb(170, 170, 170);
        public Color ValueColor { get; set; } = Color.FromArgb(255, 255, 255);

        // 뱃지 및 상태 색상
        public Color BadgeBackColor { get; set; } = Color.FromArgb(26, 28, 30);
        public Color UpColor { get; set; } = Color.FromArgb(72, 199, 142);    // Spring Green
        public Color DownColor { get; set; } = Color.FromArgb(229, 83, 80);   // Vivid Red
        public Color FlatColor { get; set; } = Color.FromArgb(144, 164, 174);

        // 보조 텍스트 (Alpha 적용)
        public Color TimeLabelColor { get; set; } = Color.FromArgb(120, 176, 190, 210);

        // 차트 및 스파크라인 (Alpha 채널 고려)
        public Color ChartUpColor { get; set; } = Color.FromArgb(0, 230, 118);
        public Color ChartDownColor { get; set; } = Color.FromArgb(255, 82, 82);
        public Color ChartFlatColor { get; set; } = Color.FromArgb(120, 144, 156);

        // 보조 텍스트 (투명도 포함)

        public int CornerRadius { get; set; } = 24;
        public int PaddingSize { get; set; } = 18;
        public int HeaderTop { get; set; } = 18;
        public int ChartHeight { get; set; } = 95;
    }
}
