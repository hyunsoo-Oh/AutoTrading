namespace KisRestAPI.Models.Accounts
{
    /// <summary>
    /// 주식통합증거금 현황 Query Parameter DTO
    ///
    /// 왜 이 API가 필요한가?
    /// - 일반계좌와 통합증거금 신청계좌의 국내/해외 주문가능금액을 간단하게 조회한다.
    /// - HTS [0867] 통합증거금조회 화면의 기능에 해당한다.
    /// - 증거금율별 주문 가능 금액(20%/30%/40%/50%/60%/100%)을 한 번에 파악할 수 있다.
    /// - 해외주식 통합증거금 주문 가능 금액(USD/HKD/JPY/CNY)도 함께 확인 가능하다.
    ///
    /// ※ 실전투자 전용 API ? 모의투자 미지원
    /// ※ 연속조회 불가 API
    /// </summary>
    public sealed class InquireIntgrMarginRequest
    {
        /// <summary>종합계좌번호 앞 8자리</summary>
        public string CANO { get; set; } = string.Empty;

        /// <summary>계좌상품코드 뒤 2자리 (보통 "01")</summary>
        public string ACNT_PRDT_CD { get; set; } = "01";

        /// <summary>
        /// CMA평가금액포함여부
        /// "N" 입력
        /// </summary>
        public string CMA_EVLU_AMT_ICLD_YN { get; set; } = "N";

        /// <summary>
        /// 원화외화구분코드
        /// "01": 외화기준, "02": 원화기준
        /// </summary>
        public string WCRC_FRCR_DVSN_CD { get; set; } = "02";

        /// <summary>
        /// 선도환계약외화구분코드
        /// "01": 외화기준, "02": 원화기준
        /// </summary>
        public string FWEX_CTRT_FRCR_DVSN_CD { get; set; } = "02";
    }
}
