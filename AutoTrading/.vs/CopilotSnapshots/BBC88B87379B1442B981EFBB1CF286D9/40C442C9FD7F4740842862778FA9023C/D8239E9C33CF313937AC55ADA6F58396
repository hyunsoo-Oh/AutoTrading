namespace AutoTrading.Features.Models.Api.Orders
{
    /// <summary>
    /// 주식정정취소가능주문조회 Query Parameter DTO
    ///
    /// 왜 Query Parameter DTO를 별도로 만드는가?
    /// - GET 방식이므로 Body가 아니라 URL QueryString으로 전달된다.
    /// - DTO에 필드를 정의하면 QueryStringBuilder가 이를 직렬화한다.
    /// - JsonPropertyName이 아닌 필드명 그대로 URL 파라미터 키로 사용한다.
    ///
    /// ※ 모의투자 미지원 — 실전투자 전용 API
    /// </summary>
    public sealed class InquirePsblRvsecnclRequest
    {
        /// <summary>종합계좌번호 앞 8자리</summary>
        public string CANO { get; set; } = string.Empty;

        /// <summary>계좌상품코드 뒤 2자리 (보통 "01")</summary>
        public string ACNT_PRDT_CD { get; set; } = "01";

        /// <summary>
        /// 연속조회검색조건100
        /// 최초 조회 시: 공란, 다음 페이지 조회 시: 이전 Output의 CTX_AREA_FK100 값
        /// </summary>
        public string CTX_AREA_FK100 { get; set; } = string.Empty;

        /// <summary>
        /// 연속조회키100
        /// 최초 조회 시: 공란, 다음 페이지 조회 시: 이전 Output의 CTX_AREA_NK100 값
        /// </summary>
        public string CTX_AREA_NK100 { get; set; } = string.Empty;

        /// <summary>
        /// 조회구분1
        /// "0": 주문 기준, "1": 종목 기준
        /// </summary>
        public string INQR_DVSN_1 { get; set; } = "0";

        /// <summary>
        /// 조회구분2
        /// "0": 전체, "1": 매도, "2": 매수
        /// </summary>
        public string INQR_DVSN_2 { get; set; } = "0";
    }
}
