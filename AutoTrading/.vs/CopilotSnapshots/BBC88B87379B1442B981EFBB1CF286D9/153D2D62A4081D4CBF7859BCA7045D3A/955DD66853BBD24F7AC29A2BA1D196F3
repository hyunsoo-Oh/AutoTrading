using AutoTrading.Features.Models.Api.Orders;
using AutoTrading.Services.KoreaInvest.Orders;
using FluentAssertions;

namespace AutoTrading.Tests.Orders
{
    /// <summary>
    /// 주식주문 정정취소 요청 검증기 단위 테스트
    ///
    /// 정정(01)과 취소(02)는 같은 API를 사용하지만 검증 규칙이 다르다.
    /// - 정정: 원주문번호 + 변경할 가격/수량이 유효해야 한다
    /// - 취소: 원주문번호 + 수량만 있으면 되고, 단가는 "0"이어야 한다
    ///
    /// 테스트 구조:
    /// - 정상 케이스 (정정 지정가, 정정 시장가, 취소)
    /// - 공통 필수 필드 누락 (Cano, AcntPrdtCd, OrgnOdno, OrdDvsn, OrdQty, OrdUnpr)
    /// - 정정취소구분(RvseCnclDvsnCd) 잘못된 값
    /// - 잔량전부주문여부(QtyAllOrdYn) 잘못된 값
    /// - 정정 시 지정가 단가 검증
    /// - 취소 시 단가 = "0" 강제
    /// </summary>
    public class OrderRvsecnclRequestValidatorTests
    {
        // ===== 정정(지정가) 정상 요청 헬퍼 =====
        private static OrderRvsecnclRequest CreateValidReviseRequest() => new()
        {
            Cano = "12345678",
            AcntPrdtCd = "01",
            KrxFwdgOrdOrgno = "",
            OrgnOdno = "0000123456",
            OrdDvsn = "00",             // 지정가
            RvseCnclDvsnCd = "01",      // 정정
            OrdQty = "5",
            OrdUnpr = "72000",          // 정정 + 지정가이므로 단가 > 0
            QtyAllOrdYn = "Y",
            CndtPric = "0",
            ExcgIdDvsnCd = "KRX"
        };

        // ===== 취소 정상 요청 헬퍼 =====
        private static OrderRvsecnclRequest CreateValidCancelRequest() => new()
        {
            Cano = "12345678",
            AcntPrdtCd = "01",
            KrxFwdgOrdOrgno = "",
            OrgnOdno = "0000123456",
            OrdDvsn = "00",             // 원주문의 주문구분
            RvseCnclDvsnCd = "02",      // 취소
            OrdQty = "5",
            OrdUnpr = "0",              // 취소 시 단가 = "0"
            QtyAllOrdYn = "Y",
            CndtPric = "0",
            ExcgIdDvsnCd = "KRX"
        };

        #region ===== 정상 케이스 =====

        [Fact]
        public void Validate_정정_지정가_정상요청_예외없음()
        {
            // Arrange — 정정(01) + 지정가(00) 정상 요청
            var request = CreateValidReviseRequest();

            // Act & Assert
            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().NotThrow();
        }

        [Fact]
        public void Validate_정정_시장가_정상요청_예외없음()
        {
            // Arrange — 정정(01) + 시장가(01) — 시장가 정정 시 단가 규칙은 별도 없음
            var request = CreateValidReviseRequest();
            request.OrdDvsn = "01";     // 시장가로 변경
            request.OrdUnpr = "0";      // 시장가이므로 단가 "0"

            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().NotThrow();
        }

        [Fact]
        public void Validate_취소_정상요청_예외없음()
        {
            // Arrange — 취소(02) 정상 요청
            var request = CreateValidCancelRequest();

            // Act & Assert
            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().NotThrow();
        }

        #endregion

        #region ===== null 요청 =====

        [Fact]
        public void Validate_요청이_null이면_ArgumentNullException()
        {
            var act = () => OrderRvsecnclRequestValidator.Validate(null!);
            act.Should().Throw<ArgumentNullException>();
        }

        #endregion

        #region ===== 계좌번호(CANO) 누락 =====

        [Theory]
        [InlineData(null)]
        [InlineData("")]
        [InlineData("   ")]
        public void Validate_계좌번호_비어있으면_ArgumentException(string? cano)
        {
            var request = CreateValidReviseRequest();
            request.Cano = cano!;

            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().Throw<ArgumentException>()
                .WithMessage("*CANO*");
        }

        #endregion

        #region ===== 계좌상품코드(ACNT_PRDT_CD) 누락 =====

        [Theory]
        [InlineData(null)]
        [InlineData("")]
        [InlineData("   ")]
        public void Validate_계좌상품코드_비어있으면_ArgumentException(string? acntPrdtCd)
        {
            var request = CreateValidReviseRequest();
            request.AcntPrdtCd = acntPrdtCd!;

            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().Throw<ArgumentException>()
                .WithMessage("*ACNT_PRDT_CD*");
        }

        #endregion

        #region ===== 원주문번호(ORGN_ODNO) 누락 =====

        [Theory]
        [InlineData(null)]
        [InlineData("")]
        [InlineData("   ")]
        public void Validate_원주문번호_비어있으면_ArgumentException(string? orgnOdno)
        {
            // Arrange — 원주문번호가 없으면 어떤 주문을 정정/취소할지 알 수 없다
            var request = CreateValidReviseRequest();
            request.OrgnOdno = orgnOdno!;

            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().Throw<ArgumentException>()
                .WithMessage("*ORGN_ODNO*");
        }

        #endregion

        #region ===== 정정취소구분코드(RVSE_CNCL_DVSN_CD) 검증 =====

        [Theory]
        [InlineData("")]
        [InlineData("00")]
        [InlineData("03")]
        [InlineData("99")]
        [InlineData("abc")]
        public void Validate_정정취소구분_잘못된값_ArgumentException(string dvsnCd)
        {
            // Arrange — "01"(정정) 또는 "02"(취소)만 허용
            var request = CreateValidReviseRequest();
            request.RvseCnclDvsnCd = dvsnCd;

            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().Throw<ArgumentException>()
                .WithMessage("*RVSE_CNCL_DVSN_CD*");
        }

        [Theory]
        [InlineData("01")]
        [InlineData("02")]
        public void Validate_정정취소구분_정상값_해당필드_예외없음(string dvsnCd)
        {
            // Arrange — 정상 구분코드로 설정 (취소 시 단가 "0" 맞춤)
            var request = dvsnCd == "01" ? CreateValidReviseRequest() : CreateValidCancelRequest();

            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().NotThrow();
        }

        #endregion

        #region ===== 주문구분(ORD_DVSN) 누락 =====

        [Theory]
        [InlineData(null)]
        [InlineData("")]
        [InlineData("   ")]
        public void Validate_주문구분_비어있으면_ArgumentException(string? ordDvsn)
        {
            var request = CreateValidReviseRequest();
            request.OrdDvsn = ordDvsn!;

            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().Throw<ArgumentException>()
                .WithMessage("*ORD_DVSN*");
        }

        #endregion

        #region ===== 주문수량(ORD_QTY) 검증 =====

        [Theory]
        [InlineData(null)]
        [InlineData("")]
        [InlineData("   ")]
        public void Validate_주문수량_비어있으면_ArgumentException(string? ordQty)
        {
            var request = CreateValidReviseRequest();
            request.OrdQty = ordQty!;

            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().Throw<ArgumentException>()
                .WithMessage("*ORD_QTY*");
        }

        [Theory]
        [InlineData("0")]
        [InlineData("-1")]
        [InlineData("abc")]
        [InlineData("-100")]
        public void Validate_주문수량_0이하_또는_숫자아님_ArgumentException(string ordQty)
        {
            var request = CreateValidReviseRequest();
            request.OrdQty = ordQty;

            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().Throw<ArgumentException>()
                .WithMessage("*ORD_QTY*");
        }

        #endregion

        #region ===== 주문단가(ORD_UNPR) 누락 =====

        [Theory]
        [InlineData(null)]
        [InlineData("")]
        [InlineData("   ")]
        public void Validate_주문단가_비어있으면_ArgumentException(string? ordUnpr)
        {
            var request = CreateValidReviseRequest();
            request.OrdUnpr = ordUnpr!;

            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().Throw<ArgumentException>()
                .WithMessage("*ORD_UNPR*");
        }

        #endregion

        #region ===== 잔량전부주문여부(QTY_ALL_ORD_YN) 검증 =====

        [Theory]
        [InlineData("")]
        [InlineData("A")]
        [InlineData("YES")]
        [InlineData("n")]
        [InlineData("y")]
        public void Validate_잔량전부주문여부_잘못된값_ArgumentException(string qtyAllOrdYn)
        {
            // Arrange — "Y" 또는 "N"만 허용 (대문자만)
            var request = CreateValidReviseRequest();
            request.QtyAllOrdYn = qtyAllOrdYn;

            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().Throw<ArgumentException>()
                .WithMessage("*QTY_ALL_ORD_YN*");
        }

        [Theory]
        [InlineData("Y")]
        [InlineData("N")]
        public void Validate_잔량전부주문여부_정상값_예외없음(string qtyAllOrdYn)
        {
            var request = CreateValidReviseRequest();
            request.QtyAllOrdYn = qtyAllOrdYn;

            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().NotThrow();
        }

        #endregion

        #region ===== 정정(01) + 지정가(00) 시 단가 검증 =====

        [Theory]
        [InlineData("0")]
        [InlineData("-500")]
        [InlineData("abc")]
        public void Validate_정정_지정가_단가_0이하_또는_비숫자_ArgumentException(string ordUnpr)
        {
            // Arrange — 정정(01) + 지정가(00)인데 단가가 유효하지 않은 경우
            var request = CreateValidReviseRequest();
            request.RvseCnclDvsnCd = "01";
            request.OrdDvsn = "00";
            request.OrdUnpr = ordUnpr;

            // Act & Assert — 정정 + 지정가는 단가 > 0 이어야 한다
            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().Throw<ArgumentException>()
                .WithMessage("*ORD_UNPR*");
        }

        [Fact]
        public void Validate_정정_지정가_단가_양수_예외없음()
        {
            var request = CreateValidReviseRequest();
            request.RvseCnclDvsnCd = "01";
            request.OrdDvsn = "00";
            request.OrdUnpr = "75000";

            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().NotThrow();
        }

        #endregion

        #region ===== 취소(02) 시 단가 = "0" 강제 =====

        [Theory]
        [InlineData("70000")]
        [InlineData("100")]
        [InlineData("1")]
        public void Validate_취소_단가가_0이_아니면_ArgumentException(string ordUnpr)
        {
            // Arrange — 취소(02) 주문인데 단가가 "0"이 아닌 경우
            var request = CreateValidCancelRequest();
            request.OrdUnpr = ordUnpr;

            // Act & Assert — 취소 주문은 단가를 "0"으로 보내야 한다
            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().Throw<ArgumentException>()
                .WithMessage("*ORD_UNPR*");
        }

        [Fact]
        public void Validate_취소_단가_0_정상_예외없음()
        {
            var request = CreateValidCancelRequest();

            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().NotThrow();
        }

        #endregion

        #region ===== 정정/취소 경계값 테스트 =====

        [Fact]
        public void Validate_정정_수량_1_최소_정상값()
        {
            var request = CreateValidReviseRequest();
            request.OrdQty = "1";

            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().NotThrow();
        }

        [Fact]
        public void Validate_취소_잔량전부_Y로_전량취소()
        {
            // Arrange — 전량 취소 시나리오
            var request = CreateValidCancelRequest();
            request.QtyAllOrdYn = "Y";

            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().NotThrow();
        }

        [Fact]
        public void Validate_취소_잔량전부_N으로_일부취소()
        {
            // Arrange — 일부 취소 시나리오
            var request = CreateValidCancelRequest();
            request.QtyAllOrdYn = "N";
            request.OrdQty = "3";

            var act = () => OrderRvsecnclRequestValidator.Validate(request);
            act.Should().NotThrow();
        }

        #endregion
    }
}
