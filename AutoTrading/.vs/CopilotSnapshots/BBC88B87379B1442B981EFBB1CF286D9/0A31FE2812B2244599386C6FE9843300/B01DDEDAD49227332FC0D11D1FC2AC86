using KisRestAPI.Common;
using KisRestAPI.Common.Http;
using KisRestAPI.Models.Accounts;

namespace KisRestAPI.Accounts
{
    // =====================================================================
    // ===== 주식잔고조회 API 빌더 통합 파일 =====
    // Validator / QueryStringBuilder / UrlBuilder / TrIdProvider /
    // HeaderBuilder / AccountProductCodeProvider를 하나로 모은다.
    // =====================================================================

    // ===== 요청 검증 =====
    internal static class InquireBalanceRequestValidator
    {
        public static void Validate(InquireBalanceRequest request)
        {
            if (request is null)
                throw new ArgumentNullException(nameof(request));
            if (string.IsNullOrWhiteSpace(request.CANO))
                throw new ArgumentException("계좌번호(CANO)가 비어 있습니다.");
            if (string.IsNullOrWhiteSpace(request.ACNT_PRDT_CD))
                throw new ArgumentException("계좌상품코드(ACNT_PRDT_CD)가 비어 있습니다.");
        }
    }

    // ===== QueryString 생성 =====
    internal static class InquireBalanceQueryStringBuilder
    {
        public static string Build(InquireBalanceRequest request)
        {
            if (request == null) throw new ArgumentNullException(nameof(request));

            var queryParameters = new Dictionary<string, string?>
            {
                ["CANO"] = request.CANO,
                ["ACNT_PRDT_CD"] = request.ACNT_PRDT_CD,
                ["AFHR_FLPR_YN"] = request.AFHR_FLPR_YN,
                ["OFL_YN"] = request.OFL_YN,
                ["INQR_DVSN"] = request.INQR_DVSN,
                ["UNPR_DVSN"] = request.UNPR_DVSN,
                ["FUND_STTL_ICLD_YN"] = request.FUND_STTL_ICLD_YN,
                ["FNCG_AMT_AUTO_RDPT_YN"] = request.FNCG_AMT_AUTO_RDPT_YN,
                ["PRCS_DVSN"] = request.PRCS_DVSN,
                ["CTX_AREA_FK100"] = request.CTX_AREA_FK100,
                ["CTX_AREA_NK100"] = request.CTX_AREA_NK100
            };

            return string.Join("&",
               queryParameters.Select(p =>
                   $"{Uri.EscapeDataString(p.Key)}={Uri.EscapeDataString(p.Value ?? string.Empty)}"));
        }
    }

    // ===== URL 생성 =====
    internal static class InquireBalanceUrlBuilder
    {
        private const string Path = "/uapi/domestic-stock/v1/trading/inquire-balance";

        public static string Build(string baseUrl, InquireBalanceRequest request)
        {
            if (string.IsNullOrWhiteSpace(baseUrl))
                throw new ArgumentException("BaseUrl이 비어 있을 수 없습니다.", nameof(baseUrl));
            if (request == null)
                throw new ArgumentNullException(nameof(request));

            string normalizedBaseUrl = baseUrl.TrimEnd('/');
            string queryString = InquireBalanceQueryStringBuilder.Build(request);
            return $"{normalizedBaseUrl}{Path}?{queryString}";
        }
    }

    // ===== TR ID 제공 — 모의투자/실전투자 모두 지원 =====
    internal class InquireBalanceTrIdProvider
    {
        private const string MockTrId = "VTTC8434R";
        private const string LiveTrId = "TTTC8434R";

        public static string Get(KisTradingMode tradingMode)
        {
            return tradingMode == KisTradingMode.Live ? LiveTrId : MockTrId;
        }
    }

    // ===== HTTP 헤더 생성 =====
    internal static class InquireBalanceHeaderBuilder
    {
        public static Dictionary<string, string> Build(
            string accessToken, string appKey, string appSecret,
            string trId, string custType = "P", string? trCont = null)
        {
            return KisHttpHeaderBuilder.BuildCommon(
                accessToken: accessToken, appKey: appKey, appSecret: appSecret,
                custType: custType,
                extraHeaders: new Dictionary<string, string>
                {
                    ["tr_id"] = trId,
                    ["tr_cont"] = trCont ?? string.Empty
                });
        }
    }

    // ===== 계좌상품코드 제공 — 실전 "01", 모의 "50" =====
    public static class InquireBalanceAccountProductCodeProvider
    {
        private const string LiveProductCode = "01";
        private const string MockProductCode = "50";

        public static string Get(KisTradingMode tradingMode)
        {
            return tradingMode == KisTradingMode.Live ? LiveProductCode : MockProductCode;
        }
    }
}
