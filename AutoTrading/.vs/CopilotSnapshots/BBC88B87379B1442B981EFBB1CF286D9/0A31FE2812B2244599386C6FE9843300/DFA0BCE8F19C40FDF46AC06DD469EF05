using KisRestAPI.Configuration;

namespace KisRestAPI.Common.Http
{
    /// <summary>
    /// 현재 선택된 한국투자증권 서버 환경을 관리하는 서비스 인터페이스
    /// </summary>
    public interface IKisTradingService
    {
        KisTradingMode CurrentEnvironment { get; }

        /// <summary>
        /// 사용자가 명시적으로 모드를 전환할 때 발생한다.
        /// 토큰 갱신 내부 루프에서는 발생하지 않는다.
        /// </summary>
        event EventHandler<KisTradingMode>? EnvironmentChanged;

        /// <summary>내부 전용 ? 이벤트 없이 환경만 변경한다. (토큰 갱신 루프 등)</summary>
        void SetEnvironment(KisTradingMode environment);

        /// <summary>사용자 액션 ? 환경을 변경하고 EnvironmentChanged 이벤트를 발생시킨다.</summary>
        void SwitchEnvironment(KisTradingMode environment);

        ApiEndpointSettings GetCurrentSettings();

        /// <summary>
        /// 현재 환경의 불변 스냅샷을 생성한다.
        /// 비동기 요청 시작 시점에 호출하면,
        /// 요청 도중에 환경이 바뀌어도 영향을 받지 않는다.
        /// </summary>
        KisRequestContext CreateSnapshot();
    }
}
